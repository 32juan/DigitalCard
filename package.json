{
  "name": "jack-tinsley-digital-card",
  "version": "1.0.0",
  "private": true,
  "description": "Static digital business card and QR landing page for Jack Tinsley.",
  "type": "commonjs",
  "scripts": {
    "test": "npm run check",
    "test:static": "playwright test tests/static.spec.js",
    "test:e2e": "playwright test tests/index.spec.js tests/editor.spec.js tests/card-preview.spec.js",
    "test:mobile": "playwright test tests/index.spec.js tests/screenshots.spec.js --project=mobile-360 --project=mobile-390 --project=mobile-430",
    "test:a11y": "playwright test tests/a11y.spec.js",
    "screenshots": "playwright test tests/screenshots.spec.js --workers=1",
    "check": "npm run test:static && npm run test:e2e && npm run test:a11y"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "axe-core": "^4.11.4",
    "http-server": "^14.1.1"
  }
}
